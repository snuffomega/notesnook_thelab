# ─── Domain ────────────────────────────────────────────────────────────────────
BASE_DOMAIN=yourdomain.com

# Subdomains (change if you want different names)
NOTESNOOK_APP_DOMAIN=notes.${BASE_DOMAIN}
NOTESNOOK_AUTH_DOMAIN=auth.${BASE_DOMAIN}
NOTESNOOK_SYNC_DOMAIN=sync.${BASE_DOMAIN}
NOTESNOOK_SSE_DOMAIN=sse.${BASE_DOMAIN}
NOTESNOOK_MONOGRAPH_DOMAIN=mono.${BASE_DOMAIN}
NOTESNOOK_S3_DOMAIN=s3.${BASE_DOMAIN}

# ─── Instance ──────────────────────────────────────────────────────────────────
INSTANCE_NAME=my-notesnook                # shown in client apps
NOTESNOOK_API_SECRET=                     # random >32 chars: openssl rand -base64 32
DISABLE_SIGNUPS=false                     # set true to lock down new registrations

# ─── SMTP (required for password reset and 2FA emails) ────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=your@email.com
SMTP_PASSWORD="your-app-password"         # Gmail: wrap 16-char app password in quotes
NOTESNOOK_SENDER_EMAIL=your@email.com
SMTP_REPLYTO_EMAIL=your@email.com

# ─── MinIO (S3-compatible attachment storage) ──────────────────────────────────
MINIO_ROOT_USER=minio                     # must be >3 chars
MINIO_ROOT_PASSWORD=                      # must be >8 chars: openssl rand -base64 12

# ─── Twilio (optional — SMS 2FA only) ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SERVICE_SID=

# ─── Public URLs (auto-derived — only change if using custom subdomain names) ──
NOTESNOOK_APP_PUBLIC_URL=https://${NOTESNOOK_APP_DOMAIN}
AUTH_SERVER_PUBLIC_URL=https://${NOTESNOOK_AUTH_DOMAIN}
NOTESNOOK_SYNC_PUBLIC_URL=https://${NOTESNOOK_SYNC_DOMAIN}
SSE_SERVER_PUBLIC_URL=https://${NOTESNOOK_SSE_DOMAIN}
MONOGRAPH_PUBLIC_URL=https://${NOTESNOOK_MONOGRAPH_DOMAIN}
ATTACHMENTS_SERVER_PUBLIC_URL=https://${NOTESNOOK_S3_DOMAIN}
NOTESNOOK_CORS_ORIGINS=                   # comma-separated allowed origins, empty = all

# ─── Web App Build Args (baked into Docker image — rebuild required if changed) ─
NN_API_HOST=${NOTESNOOK_SYNC_PUBLIC_URL}
NN_AUTH_HOST=${AUTH_SERVER_PUBLIC_URL}
NN_SSE_HOST=${SSE_SERVER_PUBLIC_URL}
NN_MONOGRAPH_HOST=${MONOGRAPH_PUBLIC_URL}

# ─── Web App Version ───────────────────────────────────────────────────────────
# Pinned Notesnook release to build from. Check: github.com/streetwriters/notesnook/releases
NOTESNOOK_VERSION=v3.3.8
