# ─── Domain ────────────────────────────────────────────────────────────────────
# Set your root domain. All service URLs are auto-derived in docker-compose.yml:
#   notes/auth/sync/sse/mono/s3.<BASE_DOMAIN>
BASE_DOMAIN=yourdomain.com

# ─── Instance ──────────────────────────────────────────────────────────────────
INSTANCE_NAME=my-notesnook               # shown in client apps
NOTESNOOK_API_SECRET=                    # openssl rand -base64 32
DISABLE_SIGNUPS=false                    # set true to lock down new registrations

# ─── SMTP (required for password reset and 2FA emails) ────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=your@email.com
SMTP_PASSWORD="your-app-password"        # Gmail: wrap 16-char app password in quotes
NOTESNOOK_SENDER_EMAIL=your@email.com
SMTP_REPLYTO_EMAIL=your@email.com

# ─── MinIO (S3-compatible attachment storage) ──────────────────────────────────
MINIO_ROOT_USER=minio                    # must be >3 chars
MINIO_ROOT_PASSWORD=                     # must be >8 chars: openssl rand -base64 12

# ─── Twilio (optional — SMS 2FA only) ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SERVICE_SID=

# ─── CORS ──────────────────────────────────────────────────────────────────────
NOTESNOOK_CORS_ORIGINS=                  # comma-separated allowed origins, empty = allow all

# ─── Web App Version ───────────────────────────────────────────────────────────
# Pinned Notesnook release to build from. Check: github.com/streetwriters/notesnook/releases
NOTESNOOK_VERSION=v3.3.8
